LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_BATCH_SIZE=32
INDEXING_BATCH_SIZE=128
PARENT_CONTEXT_MAX_CHARS=3000
# Use EMBEDDING_MODEL=local-hash for an offline demo that does not download Hugging Face models.
OLLAMA_OPENAI_BASE_URL=http://localhost:11434/v1
RAGAS_EMBEDDING_PROVIDER=huggingface
RAGAS_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
RAGAS_JUDGE_MAX_TOKENS=4096
CHROMA_PERSIST_DIR=vector_db
CHROMA_COLLECTION_NAME=document_qa_vietnamese
TOP_K=5
SIMILARITY_THRESHOLD=0.3
USE_HYBRID_SEARCH=true
HYBRID_ALPHA=0.7
USE_MMR=true
RERANKER_MODEL=
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
